body {
    margin: 0;
    font-family: Arial;
    text-align: center;
    background: yellow;
}

h1 {
    padding: 20px;
}

.gallery {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    padding: 20px;
}

.gallery img {
    width: 200px;
    height: 200px;
    border-radius: 10px;
    transition: 0.5s;
}

.gallery img:hover {
    transform: scale(1.1);
    box-shadow: 0 0 20px black;
}
